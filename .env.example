# Kimi 2.6 Vision API
KIMI_API_KEY=your-moonshot-api-key-here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# AI Controller
TICK_RATE=2.0                    # Seconds between decision cycles
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR

# Screen Capture
CAPTURE_WIDTH=1280               # Screenshot resize width
CAPTURE_HEIGHT=720               # Screenshot resize height
CAPTURE_MONITOR=1                # Monitor index (1 = primary)
CAPTURE_QUALITY=85               # JPEG quality (1-100)

# Server State Bridge
SERVER_STATE_URL=http://localhost:8080/ai-state
SERVER_STATE_FILE=               # Fallback: path to state JSON file
SERVER_STATE_TIMEOUT=5.0         # HTTP request timeout in seconds

# Memory & Learning
MEMORY_PATH=data/experience_memory.json
MAX_SHORT_TERM_MEMORY=20         # Number of recent interactions to keep in context

# Reflexes
REFLEX_ENABLED=true              # Enable hardcoded combat reflexes
REFLEX_MELEE_RANGE=3.0           # Distance in meters for melee reflex
REFLEX_LOW_HEALTH_THRESHOLD=0.3  # Health fraction to trigger heal reflex

# Navigation
LANDMARK_DB_PATH=data/landmarks.json
